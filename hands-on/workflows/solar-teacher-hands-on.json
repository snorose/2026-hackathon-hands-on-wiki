    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first();\nconst body = item.json.body || item.json;\nconst incomingBinary = item.binary || {};\nconst binaryKeys = Object.keys(incomingBinary);\nconst rawText = String(body.content || '').trim();\nconst referenceText = String(body.reference_text || body.referenceText || '').trim();\nconst fileBase64 = String(body.file_base64 || body.fileBase64 || '').trim();\nconst fileName = body.file_name || body.fileName || 'note-upload';\nconst mimeType = body.mime_type || body.mimeType || 'application/octet-stream';\nlet normalizedBinary = {};\nlet fileSource = '';\n\nif (fileBase64) {\n  const base64Data = fileBase64.includes(',') ? fileBase64.split(',').pop() : fileBase64;\n  normalizedBinary.document = {\n    data: base64Data,\n    fileName,\n    mimeType,\n  };\n  fileSource = 'json_base64';\n} else if (incomingBinary.document || incomingBinary.data || binaryKeys.length) {\n  const fileBinaryProperty = incomingBinary.document ? 'document' : incomingBinary.data ? 'data' : binaryKeys[0];\n  normalizedBinary.document = incomingBinary[fileBinaryProperty];\n  fileSource = 'webhook_binary:' + fileBinaryProperty;\n}\n\nreturn [{\n  json: {\n    raw_text: rawText,\n    reference_text: referenceText,\n    hasText: rawText.length > 0,\n    hasDocument: Boolean(normalizedBinary.document),\n    fileSource,\n  },\n  binary: normalizedBinary,\n}];"
      },
