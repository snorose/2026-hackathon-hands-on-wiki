    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const prepared = $('Prepare Prompts').first().json;\nif (prepared.error) return [{ json: { error: prepared.error } }];\n\nconst feedbackResponse = $('Upstage Feedback').first().json;\nconst quizResponse = $('Upstage Quiz').first().json;\n\nfunction getContent(response) {\n  return response?.choices?.[0]?.message?.content || '';\n}\n\nfunction stripJsonFence(value) {\n  let text = String(value || '').trim();\n  const fence = String.fromCharCode(96, 96, 96);\n  if (text.startsWith(fence + 'json')) text = text.slice(7).trim();\n  else if (text.startsWith(fence)) text = text.slice(3).trim();\n  if (text.endsWith(fence)) text = text.slice(0, -3).trim();\n  return text;\n}\n\nfunction parseQuizzes(value) {\n  try {\n    const parsed = JSON.parse(stripJsonFence(value));\n    if (Array.isArray(parsed)) return parsed;\n    if (Array.isArray(parsed.quiz)) return parsed.quiz;\n  } catch (error) {}\n  return [];\n}\n\nreturn [{\n  json: {\n    raw_text: prepared.raw_text,\n    reference_used: Boolean(prepared.reference_used),\n    feedback: getContent(feedbackResponse),\n    quizzes: parseQuizzes(getContent(quizResponse)),\n    mode: 'n8n-json-base64-to-ocr',\n  },\n}];"
      },
