      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const normalized = $('Normalize Input').first().json;\nconst ocr = $('Upstage OCR').first().json;\nconst rawText = String(ocr.text || '').trim();\n\nif (!rawText) {\n  return [{ json: { error: 'OCR 결과에서 텍스트를 찾지 못했습니다. 더 선명한 이미지나 텍스트 입력을 사용해주세요.' } }];\n}\n\nreturn [{\n  json: {\n    raw_text: rawText,\n    reference_text: normalized.reference_text,\n  },\n}];"
      },
